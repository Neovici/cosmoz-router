{
  "name": "@neovici/cosmoz-router",
  "version": "11.3.0",
  "description": "A Polymer component to handle client side URL routing and view loading / management",
  "keywords": [
    "polymer",
    "web-components"
  ],
  "type": "module",
  "homepage": "https://github.com/Neovici/cosmoz-router#readme",
  "bugs": {
    "url": "https://github.com/Neovici/cosmoz-router/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Neovici/cosmoz-router.git"
  },
  "license": "Apache-2.0",
  "author": "",
  "main": "dist/index.js",
  "directories": {
    "test": "test"
  },
  "files": [
    "dist/*"
  ],
  "scripts": {
    "lint": "tsc && eslint --cache .",
    "check:duplicates": "check-duplicate-components",
    "build": "tsc -p tsconfig.build.json",
    "start": "wds",
    "storybook:start": "storybook dev -p 8000",
    "storybook:build": "storybook build",
    "storybook:deploy": "storybook-to-ghpages",
    "storybook:preview": "npm run storybook:build && http-server ./storybook-static/ --silent",
    "test": "wtr --coverage",
    "test:watch": "wtr --watch",
    "prepare": "husky",
    "changeset": "changeset"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./dist/index.js",
    "./use-hash-param": "./dist/use-hash-param.js"
  },
  "dependencies": {
    "@pionjs/pion": "^2.5.2",
    "lit": "^3.0.0",
    "lit-html": "^3.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@neovici/cfg": "^2.8.0",
    "@open-wc/testing": "^4.0.0",
    "@storybook/web-components-vite": "^10.0.0",
    "@types/mocha": "^10.0.3",
    "@web/dev-server": "^0.4.0",
    "@web/test-runner": "^0.20.2",
    "http-server": "^14.1.1",
    "husky": "^9.0.0",
    "lint-staged": "^17.0.7",
    "rollup-plugin-esbuild": "^6.1.1",
    "sinon": "^22.0.0",
    "storybook": "^10.0.0"
  }
}
